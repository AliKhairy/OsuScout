<Window x:Class="OsuScoutNew.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="OsuScout Overlay" Height="480" Width="820"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        WindowStartupLocation="CenterScreen"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- Palette: keep this to ONE accent so it stays intentional -->
        <SolidColorBrush x:Key="AccentBrush" Color="#FF66AB"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="#552B2233"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#EE181818"/>
        <SolidColorBrush x:Key="RowHoverBrush" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="FieldBrush" Color="#22FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF5F5F5"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#99FFFFFF"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#66FFFFFF"/>

        <!-- Chrome buttons (minimize/close) -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary action button (Inject Selection) -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#1A0510"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (Scan Folder) -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Search/filter fields -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource FieldBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource PanelBrush}" CornerRadius="14" BorderBrush="{StaticResource AccentDimBrush}" BorderThickness="1" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.35" Color="Black"/>
        </Border.Effect>
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Grid Grid.Row="0" Margin="0,0,0,16" MouseDown="Window_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="OSUSCOUT" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text="ENGINE" Foreground="{StaticResource TextMutedBrush}" FontSize="13" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="💖 DONATE" Foreground="#FF69B4" Style="{StaticResource ChromeButton}" Width="65" FontSize="10" Click="DonateButton_Click" Margin="0,0,10,0" ToolTip="Support the developer"/>
                    <Button Content="⚙ DIR" Style="{StaticResource ChromeButton}" Width="45" FontSize="10" Click="ChangeFolderButton_Click" Margin="0,0,10,0" ToolTip="Change Songs Folder"/>
                    <Button Content="—" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" Margin="0,0,4,0"/>
                    <Button Content="✕" Style="{StaticResource ChromeButton}" Foreground="#FA5252" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Filters -->
            <StackPanel Grid.Row="1" Margin="0,0,0,14">
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="SEARCH" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="2,0,0,4"/>
                        <TextBox x:Name="SearchBox" Height="30" TextChanged="SearchInput_TextChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                        <TextBlock Text="TAGS (Use '-' to exclude and ',' to seperate tags)" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="Bold" Margin="2,0,0,4"/>
                        <ComboBox x:Name="TagSearchBox" Height="30" IsEditable="True"
                                  TextBoxBase.TextChanged="SearchInput_TextChanged"
                                  SelectionChanged="TagSearchBox_SelectionChanged"/>
                    </StackPanel>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold">
                            <Run Text="STARS: "/>
                            <Run Text="{Binding LowerValue, ElementName=StarSlider, StringFormat={}{0:F1}}"/>
                            <Run Text="★ - "/>
                            <Run Text="{Binding UpperValue, ElementName=StarSlider, StringFormat={}{0:F1}}"/>
                            <Run Text="★"/>
                        </TextBlock>
                        <mah:RangeSlider x:Name="StarSlider" Minimum="0" Maximum="10" LowerValue="0" UpperValue="10" TickFrequency="0.5" IsSnapToTickEnabled="True" LowerValueChanged="Slider_ValueChanged" UpperValueChanged="Slider_ValueChanged" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="5,0,5,0">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold">
                            <Run Text="BPM: "/>
                            <Run Text="{Binding LowerValue, ElementName=BpmSlider, StringFormat={}{0:F0}}"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding UpperValue, ElementName=BpmSlider, StringFormat={}{0:F0}}"/>
                        </TextBlock>
                        <mah:RangeSlider x:Name="BpmSlider" Minimum="0" Maximum="300" LowerValue="0" UpperValue="300" TickFrequency="10" IsSnapToTickEnabled="True" LowerValueChanged="Slider_ValueChanged" UpperValueChanged="Slider_ValueChanged" Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold">
                            <Run Text="LENGTH: "/>
                            <Run Text="{Binding LowerValue, ElementName=LengthSlider}"/>
                            <Run Text=" - "/>
                            <Run Text="{Binding UpperValue, ElementName=LengthSlider}"/>
                            <Run Text=" MINS"/>
                        </TextBlock>
                        <mah:RangeSlider x:Name="LengthSlider" Minimum="1" Maximum="20" LowerValue="1" UpperValue="20" TickFrequency="1" IsSnapToTickEnabled="True" LowerValueChanged="Slider_ValueChanged" UpperValueChanged="Slider_ValueChanged" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
                <TextBlock Text="💡 Tip: Hold Shift while clicking column headers to sort by multiple columns." Foreground="{StaticResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Right" Margin="0,10,0,0" FontStyle="Italic"/>
            </StackPanel>

            <Border Grid.Row="2" Background="#14000000" CornerRadius="8" BorderBrush="#14FFFFFF" BorderThickness="1">
                <DataGrid x:Name="BeatmapGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" MouseDoubleClick="BeatmapGrid_MouseDoubleClick"
                          Background="Transparent" BorderThickness="0"
                          Foreground="{StaticResource TextPrimaryBrush}" RowBackground="Transparent"
                          GridLinesVisibility="None" HeadersVisibility="Column"
                          RowHeaderWidth="0" VerticalGridLinesBrush="Transparent"
                          CanUserResizeRows="False" CanUserSortColumns="True"
                          Sorting="BeatmapGrid_Sorting">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridColumnHeader">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                    <Path x:Name="SortArrow" Margin="6,0,0,0" VerticalAlignment="Center" Width="8" Height="5" Stretch="Fill" Fill="{TemplateBinding Foreground}" Visibility="Collapsed" />
                                                </StackPanel>
                                            </Border>
                                            <Thumb x:Name="PART_RightHeaderGripper" HorizontalAlignment="Right" Width="2" Cursor="SizeWE">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Border Background="Transparent"/>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="SortDirection" Value="Ascending">
                                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 5 L 4 0 L 8 5 Z"/>
                                            </Trigger>
                                            <Trigger Property="SortDirection" Value="Descending">
                                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="SortArrow" Property="Data" Value="M 0 0 L 4 5 L 8 0 Z"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource RowHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentDimBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ARTIST" Binding="{Binding Artist}" Width="*"/>
                        <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="1.5*"/>
                        <DataGridTextColumn Header="DIFF" Binding="{Binding Version}" Width="*"/>
                        <DataGridTextColumn Header="★" Binding="{Binding StarRating, StringFormat={}{0:F2}}" Width="0.5*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="AI TAGS" Width="2*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Tags}" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" LineHeight="16"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Actions & Hotkey Notice -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <StackPanel x:Name="HotkeyPanel" Orientation="Horizontal" Visibility="Visible">
                        <Border Background="#22FFFFFF" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                            <TextBlock Text="ALT + S" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="TO TOGGLE OVERLAY IN-GAME" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel x:Name="ProgressPanel" Orientation="Horizontal" Visibility="Collapsed">
                        <ProgressBar x:Name="ScanProgressBar" Width="150" Height="6" Minimum="0" Maximum="100" Margin="0,0,10,0" Background="{StaticResource FieldBrush}" Foreground="{StaticResource AccentBrush}" BorderThickness="0" />
                        <TextBlock x:Name="ScanProgressText" Text="Scanning... 0%" Foreground="{StaticResource TextPrimaryBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>

                </StackPanel>

                <Button x:Name="PlayButton" Content="Copy Search to Clipboard" Width="180" Height="34" 
                        HorizontalAlignment="Right" Click="PlayButton_Click" Style="{StaticResource PrimaryButton}"/>
            </Grid>
        </Grid>
    </Border>
</Window>
